# ─── Environment variables ────────────────────────────────────────────────────
# Copy to `.env.local` for local dev, and set the same keys in the Vercel project
# settings for production. `.env.local` is gitignored — never commit real secrets.

# ── Server-side (Vercel serverless functions) ──

# Google service account JSON (raw JSON or base64-encoded). Used for Calendar + Sheets.
GOOGLE_SERVICE_ACCOUNT_KEY=

# Calendar to read free/busy from and write bookings to. Single ID or comma-separated list.
GOOGLE_CALENDAR_ID=

# Google Places (public reviews widget).
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# Google Sheet that collects unanswered FAQ questions (optional; endpoint 503s if unset).
FAQ_LOG_SHEET_ID=

# Comma-separated list of origins allowed to call the API cross-origin.
# Defaults to the production domain(s) if unset. Add http://localhost:5173 for local dev.
ALLOWED_ORIGINS=https://eliteaufbereitung.at,https://www.eliteaufbereitung.at

# Cloudinary cloud name — used to validate that submitted photo URLs really point
# at our Cloudinary account. Defaults to the current cloud name if unset.
CLOUDINARY_CLOUD_NAME=ddtmjszd6

# Where the server-side booking notification email is sent (FormSubmit).
NOTIFY_EMAIL=info.eliteaufbereitung@gmail.com

# ── Client-side (Vite — inlined into the bundle at build time, so NOT secret) ──

# Base URL for the API. Empty = same origin (normal for the Vercel deployment).
VITE_API_BASE=

# Make.com fallback webhook, used ONLY if /api/book is unreachable. Leaving this
# empty disables the fallback (recommended once /api/book is confirmed live).
# NOTE: whatever you put here is publicly visible in the shipped JS — use a
# dedicated, rotatable webhook and secure the Make scenario itself.
VITE_MAKE_WEBHOOK_URL=
